{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ArtEZ Notulist",
  "version": "1.0.0",
  "identifier": "nl.artez.notulist",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ArtEZ Notulist",
        "width": 940,
        "height": 820,
        "minWidth": 720,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../templates/*": "templates/"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["Dutch", "English"]
      }
    }
  },
  "plugins": {}
}
